{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "replicaCount": {
      "type": "integer",
      "minimum": 1
    },
    "image": {
      "type": "object",
      "properties": {
        "repository": { "type": "string", "minLength": 1 },
        "tag": { "type": "string" },
        "pullPolicy": {
          "type": "string",
          "enum": ["Always", "IfNotPresent", "Never"]
        }
      }
    },
    "config": {
      "type": "object",
      "properties": {
        "platformUrl": { "type": "string" },
        "websocketUrl": { "type": "string" },
        "tls": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "additionalCaBundle": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "inlinePem": { "type": "string" },
                "configMapKeyRef": {
                  "oneOf": [
                    { "type": "null" },
                    {
                      "type": "object",
                      "additionalProperties": false,
                      "required": ["name", "key"],
                      "properties": {
                        "name": { "type": "string", "minLength": 1 },
                        "key": { "type": "string", "minLength": 1 }
                      }
                    }
                  ]
                },
                "secretKeyRef": {
                  "oneOf": [
                    { "type": "null" },
                    {
                      "type": "object",
                      "additionalProperties": false,
                      "required": ["name", "key"],
                      "properties": {
                        "name": { "type": "string", "minLength": 1 },
                        "key": { "type": "string", "minLength": 1 }
                      }
                    }
                  ]
                }
              },
              "allOf": [
                {
                  "not": {
                    "required": ["configMapKeyRef", "secretKeyRef"],
                    "properties": {
                      "configMapKeyRef": { "type": "object" },
                      "secretKeyRef": { "type": "object" }
                    }
                  }
                },
                {
                  "not": {
                    "required": ["inlinePem", "configMapKeyRef"],
                    "properties": {
                      "inlinePem": { "type": "string", "minLength": 1 },
                      "configMapKeyRef": { "type": "object" }
                    }
                  }
                },
                {
                  "not": {
                    "required": ["inlinePem", "secretKeyRef"],
                    "properties": {
                      "inlinePem": { "type": "string", "minLength": 1 },
                      "secretKeyRef": { "type": "object" }
                    }
                  }
                }
              ]
            }
          }
        },
        "clusterId": { "type": "string" },
        "agentKey": { "type": "string" },
        "watchNamespaces": { "type": "string" },
        "logLevel": {
          "type": "string",
          "enum": ["info", "debug", "error", "trace", "warn"]
        },
        "handshakeProbeTimeoutMs": {
          "type": "integer",
          "minimum": 1
        },
        "k8sConcurrency": {
          "type": "integer",
          "minimum": 1,
          "maximum": 50
        },
        "k8sListPageLimit": {
          "type": "integer",
          "minimum": 1,
          "maximum": 1000
        },
        "toolReadConcurrency": { "type": "integer", "minimum": 1, "maximum": 4 },
        "toolWriteConcurrency": { "type": "integer", "minimum": 1, "maximum": 1 },
        "toolQueueLimit": { "type": "integer", "minimum": 0, "maximum": 16 },
        "toolMaxInputBytes": { "type": "integer", "minimum": 1024, "maximum": 1048576 },
        "toolMaxOutputBytes": { "type": "integer", "minimum": 1024, "maximum": 2097152 },
        "scaleMaxReplicas": { "type": "integer", "minimum": 1, "maximum": 100 },
        "allowScaleToZero": { "type": "boolean" },
        "localFallbackEnabled": { "type": "boolean" }
      }
    },
    "leaderElection": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "leaseName": { "type": "string", "minLength": 1 },
        "leaseNamespace": { "type": "string" },
        "leaseDurationMs": {
          "type": "integer",
          "minimum": 1
        },
        "renewDeadlineMs": {
          "type": "integer",
          "minimum": 1
        },
        "retryPeriodMs": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "existingSecret": {
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "key": { "type": "string", "minLength": 1 }
      }
    },
    "namespaceScope": {
      "type": "object",
      "properties": {
        "include": {
          "type": "array",
          "maxItems": 1000,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1, "maxLength": 63, "pattern": "^[a-z0-9](?:[a-z0-9-]{0,61}[a-z0-9])?$" }
        },
        "exclude": {
          "type": "array",
          "maxItems": 1000,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1, "maxLength": 63, "pattern": "^[a-z0-9](?:[a-z0-9-]{0,61}[a-z0-9])?$" }
        }
      }
    },
    "rbac": {
      "type": "object",
      "properties": {
        "create": { "type": "boolean" },
        "scope": {
          "type": "string",
          "enum": ["cluster", "namespace"]
        },
        "namespaces": {
          "type": "array",
          "maxItems": 1000,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1, "maxLength": 63, "pattern": "^[a-z0-9](?:[a-z0-9-]{0,61}[a-z0-9])?$" }
        },
        "write": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" }
          }
        }
      }
    },
    "patchPolicy": {
      "type": "object",
      "properties": {
        "kinds": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": ["Deployment", "StatefulSet", "DaemonSet", "CronJob", "Service", "Ingress"]
          }
        },
        "allowServiceSelectorChanges": { "type": "boolean" }
      },
      "required": ["kinds", "allowServiceSelectorChanges"]
    },
    "topologySpreadConstraints": {
      "type": "array"
    },
    "podDisruptionBudget": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "minAvailable": {
          "oneOf": [
            { "type": "integer", "minimum": 1 },
            { "type": "string", "minLength": 1 }
          ]
        }
      }
    }
  }
}
